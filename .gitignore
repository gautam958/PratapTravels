# ============================================
# Pratap Travels - Git Ignore
# ============================================

# --- OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath
*.sublime-workspace
*.sublime-project

# --- Node (if backend added later) ---
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# --- Environment / Credentials ---
.env
.env.local
.env.production
.env.development
*.env

# --- Build Output ---
dist/
build/
*.min.js
*.min.css

# --- Logs ---
logs/
*.log

# --- Miscellaneous ---
*.bak
*.tmp
*.cache
coverage/
*.map

# --- Generated Files ---
# Keep images, but ignore any temp/processed versions
images/**/*.tmp
images/**/*.temp


